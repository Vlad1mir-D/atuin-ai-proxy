# Select one: openai, codex-token, codex-oauth
BACKEND=openai

# Required unless Atuin sends [ai].model through its config.
MODEL=

# Optional but recommended. Use the same value in Atuin [ai].api_token.
ATUIN_PROXY_TOKEN=change-me

# OpenAI backend.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Codex token backend.
CODEX_ACCESS_TOKEN=
CODEX_ACCOUNT_ID=
CODEX_FEDRAMP=false

# Codex OAuth backend.
CODEX_HOME=/data/codex
CODEX_AUTH_FILE=
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_ISSUER=https://auth.openai.com
CODEX_AUTH_API_BASE_URL=https://auth.openai.com

REQUEST_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
